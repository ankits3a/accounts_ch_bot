# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive (Service Account JSON file path)
GOOGLE_CREDENTIALS_FILE=credentials.json

# ID of the shared Google Drive folder
# Get from folder URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# Local DB path
DATABASE_PATH=invoices.db

# Seconds before auto-saving if user takes no action
PENDING_TIMEOUT=120

# Comma-separated Telegram user IDs allowed to use the bot. Leave empty to allow all.
ALLOWED_USERS=
